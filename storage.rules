rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Cotações — leitura por todos com acesso, escrita apenas compradores
    match /pedidos/{pedidoId}/cotacoes/{cotacaoId}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.perfil in ['supremo', 'gestor', 'comprador']
        && request.resource.size < 10 * 1024 * 1024  // 10 MB
        && request.resource.contentType.matches('application/pdf|image/.*');
    }

    // Comprovantes — leitura por todos, escrita apenas financeiro/gestor
    match /pedidos/{pedidoId}/comprovantes/{parcelaId}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.perfil in ['supremo', 'gestor', 'financeiro']
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf|image/.*');
    }

  }
}
